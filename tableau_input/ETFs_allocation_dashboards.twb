      <aliases enabled='yes' />
      <column caption='Industry Weight Decimal' datatype='real' default-format='p0.0%' name='[Calculation_0895291082854401]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[weight (etf!industry!exposure!monthly)] / 100' />
      </column>
      <column caption='Geo Weight Decimal' datatype='real' default-format='p0.0%' name='[Calculation_0895291082993666]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[weight] / 100' />
      </column>
      <column caption='Is Mappable Country' datatype='boolean' name='[Calculation_0895291083182083]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[geography_name] &lt;&gt; &quot;Other Countries&quot;' />
      </column>
      <column caption='Standart Deviation Decimal' datatype='real' default-format='p0.0%' name='[Calculation_0895291084894212]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[standard_deviation_3y] / 100' />
      </column>
      <column caption='Correlations' datatype='real' default-format='p0.0%' name='[Calculation_1608050079207424]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CORR([log_return], [log_return (etf!market!monthly1)])' />
      </column>
      <column caption='Keep Column ETF in Selected Universe' datatype='boolean' name='[Calculation_1608050089709574]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='{ FIXED [etf_id (etf!market!monthly1)] :&#13;&#10;    MAX(&#13;&#10;        IF [etf_id] = [etf_id (etf!market!monthly1)]&#13;&#10;        THEN 1&#13;&#10;        ELSE 0&#13;&#10;        END&#13;&#10;    )&#13;&#10;} = 1' />
      </column>
      <column caption='Intro text' datatype='string' name='[Calculation_1608050131406857]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;intro text for story&quot;' />
      </column>
      <column caption='Expense Ratio Decimal' datatype='real' default-format='p0.0%' name='[Calculation_1912614150447104]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [etf_id (etf!metric!monthly)] : MAX([expense_ratio]) } / 100' />
      </column>
      <column caption='Bid-Ask Spread Decimal' datatype='real' default-format='p0.000%' name='[Calculation_1912614150705153]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [etf_id (etf!metric!monthly)] : MAX([bid_ask_spread_30d]) } / 100' />
      </column>
      <column caption='AUM, $bn' datatype='real' default-format='n#,##0.0;-#,##0.0' name='[Calculation_1912614150909954]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [etf_id (etf!metric!monthly)] : MAX([net_assets_usd]) } / 1000000000' />
      </column>
      <column caption='3Y Standard Deviation Decimal' datatype='real' default-format='p0.0%' name='[Calculation_1912614151139331]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[standard_deviation_3y] / 100' />
      </column>
      <column caption='Annualized Return' datatype='real' default-format='p0.0%' name='[Calculation_1912614151389188]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='EXP(12 * AVG([log_return])) - 1' />
      </column>
      <column caption='Annualized Volatility' datatype='real' default-format='p0.0%' name='[Calculation_1912614151610373]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='STDEV([monthly_return]) * SQRT(12)' />
      </column>
      <column caption='Sharpe Ratio' datatype='real' default-format='n#,##0.00;-#,##0.00' name='[Calculation_1912614152405002]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Calculation_1912614151389188] - [Parameters].[Parameter 1912614152118281]) / [Calculation_1912614151610373]' />
      </column>
      <column caption='Latest 12M Momentum' datatype='real' name='[Calculation_1912614152601611]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG(&#13;&#10;IF [month_id] = 202606 THEN [momentum_12m] END&#13;&#10;)' />
      </column>
      <column caption='Latest Cumulative Return' datatype='real' default-format='p0.0%' name='[Calculation_1912614152912908]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG(&#13;&#10;IF [month_id] = 202606 THEN [cumulative_return_index] END&#13;&#10;) - 1' />
      </column>
