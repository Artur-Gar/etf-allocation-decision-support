          <formatted-text>
            <run fontalignment='1' fontname='Tableau Medium'>Risk ranking by Sharpe Ratio</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='etf_geography_exposure_monthly+ (tableau_data_final)' name='federated.1naosg50h8d67913s3yj61krvr6c' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='Risk-free Rate' datatype='real' default-format='p0.0%' name='[Parameter 1912614152118281]' param-domain-type='any' role='measure' type='quantitative' value='0.03'>
              <calculation class='tableau' formula='0.03' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.1naosg50h8d67913s3yj61krvr6c'>
            <column caption='Annualized Return' datatype='real' default-format='p0.0%' name='[Calculation_1912614151389188]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='EXP(12 * AVG([log_return])) - 1' />
            </column>
            <column caption='Annualized Volatility' datatype='real' default-format='p0.0%' name='[Calculation_1912614151610373]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='STDEV([monthly_return]) * SQRT(12)' />
            </column>
            <column caption='Sharpe Ratio' datatype='real' default-format='n#,##0.00;-#,##0.00' name='[Calculation_1912614152405002]' role='measure' type='quantitative'>
